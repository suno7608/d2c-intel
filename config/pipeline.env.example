# Timezone and report schedule context
TZ=Asia/Seoul

# Optional runner commands
# - Runner는 아래 인자를 순서대로 받습니다.
#   1) prompt file path
#   2) input file path
#   3) output file path
#   4) metadata file path
# 예시(사용자 환경에 맞게 수정 필요):
# OPENCLAW_RUNNER="/usr/local/bin/openclaw_runner"
# CLAUDE_RUNNER="/usr/local/bin/claude_runner"
OPENCLAW_RUNNER=
CLAUDE_RUNNER=
CLAUDE_TRANSLATE_RUNNER=
OPENCLAW_AGENT_ID=main
OPENCLAW_ALT_AGENT_IDS=
OPENCLAW_TIMEOUT_SECONDS=600
OPENCLAW_MAX_RETRIES=3
OPENCLAW_BACKOFF_BASE_SECONDS=10
OPENCLAW_BACKOFF_MULTIPLIER=2
OPENCLAW_BACKOFF_CAP_SECONDS=180
OPENCLAW_JITTER_MAX_SECONDS=7
OPENCLAW_RATE_LIMIT_EXTRA_SECONDS=25
OPENCLAW_SESSION_LOCK_EXTRA_SECONDS=15
OPENCLAW_ENABLE_STALE_LOCK_CLEANUP=1
OPENCLAW_ADAPTIVE_POLICY_MAX_LEVEL=3
ENABLE_OPENCLAW_LAST_SUCCESS_FALLBACK=1
MAX_COLLECTION_STALENESS_DAYS=21
MIN_RECORDS=200
MIN_COUNTRIES=16
MIN_FRIDGE=40
MIN_WASHER=35
MIN_MONITOR=15
MIN_GRAM=10
MAX_TV_RATIO=45
CLAUDE_MODEL=
CLAUDE_TIMEOUT_SECONDS=90
CLAUDE_TRANSLATE_TIMEOUT_SECONDS=180
ENABLE_GOOGLE_TRANSLATE_FALLBACK=1
ENABLE_OFFLINE_EN_STUB_FALLBACK=1

# Data enrichment flags
ENABLE_DEEP_FETCH=0
DEEP_FETCH_MAX=50
ENABLE_DDG_SUPPLEMENT=1
DDG_MAX_QUERIES=30

# Optional behavior flags
ENABLE_CLAUDE_COWORK=1
ENABLE_PREFLIGHT_CHECK=1
PREFLIGHT_FAIL_OPEN=0
ENABLE_PREFLIGHT_OPENCLAW_SMOKE=0
OPENCLAW_SMOKE_TIMEOUT_SECONDS=30
FAIL_ON_MISSING_LINK=0
ENABLE_PUBLISHABLE_BUILD=1
ENABLE_QUALITY_GATE=1
ENABLE_OBSIDIAN_EXPORT=0
ENABLE_SHARED_PUBLISH=0
SHARED_PUBLISH_ROOT=
SHARED_BASE_URL=
ENABLE_TEAMS_NOTIFY=0
TEAMS_WEBHOOK_URL=
TEAMS_DRY_RUN=0
ALLOW_OPENCLAW_PLACEHOLDER=0
ALLOW_CLAUDE_FALLBACK_COPY=0
ALLOW_EN_HANGUL=0
FAIL_ON_STALE_COLLECTION=0

# Report metadata
REPORT_VERSION_PREFIX="Weekly Vol."
REPORT_PREPARED_BY="D2C Global Intelligence (OpenClaw Automated)"
REPORT_DISTRIBUTION="D2C Leadership / Confidential"

# Obsidian export settings
# 예시:
# OBSIDIAN_WEEKLY_ROOT="/Users/soonho/Documents/Obsidian MacMini/Global D2C Weekly Intelligence"
# OBSIDIAN_WEEKLY_FOLDER="2026-02-14 Weekly Intelligence"
OBSIDIAN_WEEKLY_ROOT=
OBSIDIAN_WEEKLY_FOLDER=

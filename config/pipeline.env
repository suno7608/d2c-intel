# Timezone and report schedule context
TZ=Asia/Seoul

# Optional runner commands
# - Runner는 아래 인자를 순서대로 받습니다.
#   1) prompt file path
#   2) input file path
#   3) output file path
#   4) metadata file path
# 예시(사용자 환경에 맞게 수정 필요):
# OPENCLAW_RUNNER="/usr/local/bin/openclaw_runner"
# CLAUDE_RUNNER="/usr/local/bin/claude_runner"
OPENCLAW_RUNNER="/Users/soonho/Documents/New project/d2c-intel/agents/openclaw_runner_cli.sh"
CLAUDE_RUNNER="/Users/soonho/Documents/New project/d2c-intel/agents/claude_runner_cli.sh"
OPENCLAW_AGENT_ID=d2cintel
OPENCLAW_TIMEOUT_SECONDS=600
MIN_RECORDS=200
MIN_COUNTRIES=16
MAX_RETRIES=2
MIN_FRIDGE=40
MIN_WASHER=35
MIN_MONITOR=15
MIN_GRAM=10
MAX_TV_RATIO=45
CLAUDE_MODEL=
CLAUDE_TIMEOUT_SECONDS=60

# Optional behavior flags
ENABLE_CLAUDE_COWORK=1
FAIL_ON_MISSING_LINK=0
ENABLE_PUBLISHABLE_BUILD=1
ENABLE_OBSIDIAN_EXPORT=1
ENABLE_SHARED_PUBLISH=0
SHARED_PUBLISH_ROOT=
SHARED_BASE_URL=
ENABLE_TEAMS_NOTIFY=0
TEAMS_WEBHOOK_URL=
TEAMS_DRY_RUN=0

# Report metadata
REPORT_VERSION_PREFIX="Weekly Vol."
REPORT_PREPARED_BY="D2C Global Intelligence (OpenClaw Automated)"
REPORT_DISTRIBUTION="D2C Leadership / Confidential"

# Obsidian export settings
OBSIDIAN_WEEKLY_ROOT="/Users/soonho/Documents/Obsidian MacMini/Global D2C Weekly Intelligence"
OBSIDIAN_WEEKLY_FOLDER=
